# Resend — https://resend.com/api-keys
# Copy this file to .env.local and fill in your key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Moyasar — https://dashboard.moyasar.com
# Test-mode keys (sk_test_/pk_test_) are issued immediately on signup, no
# merchant approval needed — see https://docs.moyasar.com/guides/card-payments/test-cards
# for test card numbers. Swap to sk_live_/pk_live_ once the real merchant
# account is approved; no code change needed, this is the only thing that flips.
MOYASAR_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Shared secret configured when creating the webhook (POST /v1/webhooks or via
# the dashboard) pointing at /api/webhooks/moyasar — must match exactly.
MOYASAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
